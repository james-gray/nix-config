<icecast>
  <location>jgray.me</location>
  <admin>admin@jgray.me</admin>

  <limits>
    <clients>30</clients>
    <sources>3</sources>
    <queue-size>524288</queue-size>
    <client-timeout>30</client-timeout>
    <header-timeout>15</header-timeout>
    <source-timeout>10</source-timeout>
    <burst-on-connect>1</burst-on-connect>
    <burst-size>65536</burst-size>
  </limits>

  <authentication>
    <source-password>supersecretpw</source-password>
    <admin-user>admin</admin-user>
    <admin-password>supersecretpw</admin-password>
  </authentication>

  <hostname>localhost</hostname>

  <listen-socket>
    <port>8000</port>
  </listen-socket>

  <mount type="normal">
    <mount-name>/music</mount-name>
    <stream-name>Music Radio</stream-name>
    <stream-description>Random albums from music.jgray.me</stream-description>
  </mount>

  <mount type="normal">
    <mount-name>/ipod</mount-name>
    <stream-name>iPod Radio</stream-name>
    <stream-description>Random tracks from ipod.jgray.me</stream-description>
  </mount>

  <mount type="normal">
    <mount-name>/bandcamp</mount-name>
    <stream-name>Bandcamp Radio</stream-name>
    <stream-description>Random albums from bandcamp.jgray.me</stream-description>
  </mount>

  <paths>
    <basedir>/usr/share/icecast2</basedir>
    <logdir>/var/log/icecast2</logdir>
    <webroot>/usr/share/icecast2/web</webroot>
    <adminroot>/usr/share/icecast2/admin</adminroot>
  </paths>

  <logging>
    <accesslog>access.log</accesslog>
    <errorlog>error.log</errorlog>
    <loglevel>3</loglevel>
  </logging>

  <security>
    <chroot>0</chroot>
  </security>
</icecast>
